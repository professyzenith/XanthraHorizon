# ── Supabase (Required) ────────────────────────────────────────────────────────
# Your project URL and anon key are safe to expose in the browser.
# SUPABASE_SERVICE_ROLE_KEY is server-only — NEVER expose it client-side.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Resend (Optional — email delivery disabled without these) ──────────────────
RESEND_API_KEY=re_your_resend_api_key_here
# IMPORTANT: onboarding@resend.dev is a SANDBOX address.
# It can ONLY deliver to the email address registered on your Resend account.
# Sending to any other recipient returns HTTP 403.
# Fix: verify your domain at resend.com/domains, then use briefing@yourdomain.com
RESEND_FROM_EMAIL=hello@xanthrahorizon.com

# ── Google Gemini (Required — free tier works) ────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Security Secrets (Required) ───────────────────────────────────────────────
# CRON_SECRET: protects /api/send-briefing and /api/test-pipeline.
# UNSUBSCRIBE_SECRET: signs unsubscribe links in emails (falls back to CRON_SECRET
#   if not set, but setting a separate value is recommended in production).
# Generate both with: openssl rand -hex 32
CRON_SECRET=your-random-secret-string-here
UNSUBSCRIBE_SECRET=your-separate-unsubscribe-secret-here

# ── App URL (Required) ────────────────────────────────────────────────────────
# Used to generate unsubscribe links in emails. Set to your production domain
# on Vercel (e.g. https://xanthrahorizon.com).
NEXT_PUBLIC_APP_URL=http://localhost:3000

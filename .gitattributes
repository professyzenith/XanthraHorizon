# Normalize line endings: LF in repo, CRLF on Windows checkout
* text=auto eol=lf

# Force LF for these types always
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.sql  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary files — no line ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
